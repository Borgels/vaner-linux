{
  "name": "vaner-desktop",
  "version": "0.3.0",
  "private": true,
  "description": "Cross-platform (Linux + Windows) desktop companion for the Vaner predictive-context engine (Tauri v2 + SvelteKit).",
  "author": "Borgels",
  "license": "Apache-2.0",
  "homepage": "https://vaner.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/Borgels/vaner-desktop.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
