[Desktop Entry]
Type=Application
Name=Vaner
GenericName=AI agent companion
Comment=Companion for the Vaner predictive-context engine
Exec=/usr/bin/env VANER_DESKTOP_SHOW_ON_START=1 /usr/bin/vaner-desktop
Icon={{icon}}
Terminal=false
Categories=Utility;
StartupNotify=true
StartupWMClass=vaner-desktop
Keywords=Vaner;AI;MCP;agent;assistant;developer;local;
